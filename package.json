{
  "name": "homebridge-tekmar-gateway",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "dist/homebridge.js",
  "types": "dist/homebridge.d.ts",
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "tekmar"
  ],
  "engines": {
    "node": "^22 || ^24"
  },
  "bin": {
    "tekmar": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "cli": "tsx src/cli.ts",
    "daemon": "tsx src/server.ts",
    "start": "node dist/server.js",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "homebridge": "^2.1.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
