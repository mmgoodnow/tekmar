{
  "name": "tekmar-homekit",
  "version": "0.1.3",
  "type": "module",
  "private": true,
  "main": "dist/homekit-cli.js",
  "types": "dist/homekit.d.ts",
  "keywords": [
    "homekit",
    "tekmar",
    "tN4"
  ],
  "engines": {
    "node": "^22 || ^24 || ^26"
  },
  "bin": {
    "tekmar-homekit": "./dist/homekit-cli.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "build:sea": "npm run build && node scripts/build-sea.js",
    "homekit": "tsx src/homekit-cli.ts",
    "start": "node dist/homekit-cli.js",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.20.6",
    "typescript": "^7.0.2",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "@homebridge/hap-nodejs": "^2.1.7"
  }
}
